{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "grant_folder": {
      "type": "string",
      "description": "Path to the local grant folder containing Announcement_Rules/ and References/"
    },
    "report_fiscal_year": {
      "type": "string",
      "description": "The fiscal year for the report (e.g., '2024')"
    },
    "pi_name_en": {
      "type": "string",
      "description": "Principal Investigator Name in English"
    },
    "pi_name_jp": {
      "type": "string",
      "description": "Principal Investigator Name in Japanese"
    },
    "pi_researcher_no": {
      "type": "string",
      "description": "e-Rad Researcher Number"
    },
    "grant_id": {
      "type": "string",
      "description": "KAKENHI Grant ID (e.g., '24K23552')"
    },
    "grant_type": {
      "type": "string",
      "description": "Type of Grant (e.g., '\u7814\u7a76\u6d3b\u52d5\u30b9\u30bf\u30fc\u30c8\u652f\u63f4')"
    },
    "is_final_year": {
      "type": "boolean",
      "description": "Flag indicating if this is the final year of the grant period"
    }
  },
  "required": [
    "grant_folder",
    "report_fiscal_year",
    "grant_id",
    "is_final_year"
  ]
}